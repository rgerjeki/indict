# Copy this file to .env and fill in the keys you have.
# indict runs with zero keys; each key you add lights up more sources.
# Never commit .env (it is gitignored). This file holds blank placeholders only.

# --- Keyed sources (optional) ---

# VirusTotal (free tier): reputation for hashes, domains, IPs, and URLs.
# https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AbuseIPDB (free tier): IP abuse confidence score and report history.
# https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# Shodan (paid/optional): open ports, services, and banners for IPs.
# Not wired in v1, reserved for later.
# SHODAN_API_KEY=

# --- Behavior (optional) ---

# Where the local response cache lives (gitignored). Default: .cache
# INDICT_CACHE_DIR=.cache

# Cache time-to-live in seconds. Default: 86400 (24h).
# INDICT_CACHE_TTL=86400

# Per-request HTTP timeout in seconds. Default: 20.
# INDICT_HTTP_TIMEOUT=20
